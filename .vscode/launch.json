{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run CyFinance",
            "type": "node-terminal",
            "request": "launch",
            "command": "dotnet build ${workspaceFolder}/src/CyFinance.csproj",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Tests",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Run Tests",
            "program": "${workspaceFolder}/tests/bin/Debug/net10.0/CyFinance.Tests.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false
        }
    ]
}